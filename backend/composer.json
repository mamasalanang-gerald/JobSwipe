{
  "name": "jobapp/backend",
  "type": "project",
  "description": "JobApp - Laravel Backend API",
  "keywords": ["laravel", "api", "jobapp"],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "aws/aws-sdk-php": "^3.374",
    "http-interop/http-factory-guzzle": "^1.2",
    "laravel/cashier": "^16.5",
    "laravel/framework": "^11.0",
    "laravel/horizon": "^5.45",
    "laravel/sanctum": "^4.3",
    "laravel/scout": "^11.1",
    "laravel/socialite": "^5.25",
    "laravel/tinker": "^2.8",
    "meilisearch/meilisearch-php": "^1.16",
    "mongodb/laravel-mongodb": "^5.6",
    "nesbot/carbon": "^2.72.6",
    "predis/predis": "^2.0",
    "resend/resend-php": "^0.13.0",
    "symfony/clock": "^7.1",
    "symfony/console": "^7.1",
    "symfony/css-selector": "^7.1",
    "symfony/event-dispatcher": "^7.1",
    "symfony/http-kernel": "^7.1",
    "symfony/mailer": "^7.1",
    "symfony/mime": "^7.1",
    "symfony/process": "^7.1",
    "symfony/routing": "^7.1",
    "symfony/string": "^7.1",
    "symfony/translation": "^7.1",
    "symfony/var-dumper": "^7.1",
    "symfony/yaml": "^7.1"
  },"spatie/laravel-ignition": "^2.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    },
    "platform": {
      "php": "8.2.30"
    },
    "process-timeout": 1800
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
