# Application
APP_NAME=JobApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=jobapp_test
DB_USERNAME=postgres
DB_PASSWORD=password

# Database - MongoDB
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=password
MONGO_DATABASE=jobapp_test

# Cache & Sessions - Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=test-jwt-secret-key-for-ci-testing
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Bcrypt
BCRYPT_ROUNDS=4

# File Storage
FILESYSTEM_DISK=local

# Queue
QUEUE_CONNECTION=sync

# Mail (optional)
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=test@example.com

# Frontend URLs
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MOBILE_URL=http://localhost:8080

# API
API_PREFIX=/api
API_VERSION=v1

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=debug
