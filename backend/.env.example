# Application
APP_NAME=JobApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=jobapp_test
DB_USERNAME=postgres
DB_PASSWORD=

# Database - MongoDB
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=
MONGO_DATABASE=jobapp_test

# Cache & Sessions - Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Bcrypt
BCRYPT_ROUNDS=4

# Admin Seeder — override these before running db:seed in production
SUPER_ADMIN_EMAIL=superadmin@jobswipe.local
SUPER_ADMIN_PASSWORD=Super@Admin123!
MODERATOR_EMAIL=moderator@jobswipe.local
MODERATOR_PASSWORD=Moderator@123!

# File Storage
FILESYSTEM_DISK=local

# Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_ACCOUNT_ID=

# Stripe Configuration
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
CASHIER_CURRENCY=php
CASHIER_CURRENCY_LOCALE=en_PH

# Apple IAP Configuration
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_BUNDLE_ID=
APPLE_IAP_WEBHOOK_ENV=PROD
APPLE_IAP_WEBHOOK_APP_APPLE_ID=
APPLE_IAP_WEBHOOK_STRICT_CERT_VALIDATION=true
# Comma-separated PEM root certificate paths inside the runtime environment
APPLE_IAP_WEBHOOK_ROOT_CERT_PATHS=/var/www/html/storage/certs/apple_root_ca_g3.pem

# Google Play IAP Configuration
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PUBSUB_WEBHOOK_AUDIENCE=
GOOGLE_PUBSUB_WEBHOOK_SERVICE_ACCOUNT=
GOOGLE_PUBSUB_REQUIRE_EMAIL_VERIFIED=true

# Queue
QUEUE_CONNECTION=sync

# Mail (optional)
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=test@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Resend (for production email)
RESEND_KEY=

# Frontend URLs
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MOBILE_URL=http://localhost:8080

# API
API_PREFIX=/api
API_VERSION=v1

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=debug
