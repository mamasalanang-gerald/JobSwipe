APP_NAME=JobApp
APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=jobapp_test
DB_USERNAME=postgres
DB_PASSWORD=password

MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=password
MONGO_AUTH_DATABASE=admin
MONGO_DATABASE=jobapp_test
MONGO_CONNECT_TIMEOUT_MS=1500
MONGO_SERVER_SELECTION_TIMEOUT_MS=1500
MONGO_SOCKET_TIMEOUT_MS=3000

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=14
REDIS_CACHE_DB=15
REDIS_PREFIX=jobapp_test_database_
REDIS_TIMEOUT=1.5
REDIS_READ_TIMEOUT=1.5

CACHE_DRIVER=redis
CACHE_PREFIX=jobapp_test_cache_
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

TEST_USE_REAL_BACKENDS=true
