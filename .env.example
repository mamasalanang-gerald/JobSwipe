# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=jobapp
DB_USERNAME=postgres
DB_PASSWORD=password

# Database - MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=password
MONGO_DATABASE=jobapp

# Cache & Sessions - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Bcrypt
BCRYPT_ROUNDS=12

# File Storage
FILESYSTEM_DISK=local

# Queue
QUEUE_CONNECTION=redis

# Mail (optional)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@jobapp.local

# Frontend URLs
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MOBILE_URL=http://localhost:8080

# API
API_PREFIX=/api
API_VERSION=v1
