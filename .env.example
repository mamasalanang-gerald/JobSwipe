# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=jobapp
DB_USERNAME=postgres
DB_PASSWORD=

# Database - MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=
MONGO_DATABASE=jobapp

# Cache & Sessions - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Bcrypt
BCRYPT_ROUNDS=12

# File Storage
FILESYSTEM_DISK=local

# Apple IAP Configuration
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_BUNDLE_ID=
APPLE_IAP_WEBHOOK_ENV=PROD
APPLE_IAP_WEBHOOK_APP_APPLE_ID=
APPLE_IAP_WEBHOOK_STRICT_CERT_VALIDATION=true
APPLE_IAP_WEBHOOK_ROOT_CERT_PATHS=/var/www/html/storage/certs/apple_root_ca_g3.pem

# Google Play IAP Configuration
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PUBSUB_WEBHOOK_AUDIENCE=
GOOGLE_PUBSUB_WEBHOOK_SERVICE_ACCOUNT=
GOOGLE_PUBSUB_REQUIRE_EMAIL_VERIFIED=true

# Queue
QUEUE_CONNECTION=redis

# Mail (optional)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@jobapp.local

# Frontend URLs
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MOBILE_URL=http://localhost:8080

# API
API_PREFIX=/api
API_VERSION=v1
