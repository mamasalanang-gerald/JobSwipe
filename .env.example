# Application
APP_NAME=JobApp
APP_ENV=local
APP_KEY=base64:TbEYUiU0ZshS+XHJEDBnUuoSGhb0OmqQYH1tRtbWpc8=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=jobapp
DB_USERNAME=postgres
DB_PASSWORD=password

# Database - MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=password
MONGO_DATABASE=jobapp

# Cache & Sessions - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# Authentication
JWT_SECRET=test-jwt-secret-key-for-ci-testing
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Bcrypt
BCRYPT_ROUNDS=4

# File Storage
FILESYSTEM_DISK=r2

# Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jobswipe
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_ACCOUNT_ID=

# Stripe Configuration
STRIPE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
CASHIER_CURRENCY=php
CASHIER_CURRENCY_LOCALE=en_PH

# Mobile IAP (false in prod)
IAP_MOCK_MODE=true

# Queue
QUEUE_CONNECTION=redis

# Mail (optional)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=jobswipe.noreply@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=jobswipe.noreply@gmail.com
MAIL_FROM_NAME="JobSwipe"

# Google OAuth Creds
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="http://localhost:8000/oauth/callback"

# Frontend URLs
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MOBILE_URL=http://localhost:8080

# API
API_PREFIX=/api
API_VERSION=v1

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=debug