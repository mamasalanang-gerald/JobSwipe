# AWS EC2 Production Environment Variables
# Copy this file to .env.production and fill in the values

# ==========================================
# DOCKER HUB
# ==========================================
DOCKER_HUB_USERNAME=your-dockerhub-username

# ==========================================
# APPLICATION
# ==========================================
APP_URL=https://jobswipe.site
APP_KEY=base64:your-generated-key-here
JWT_SECRET=your-jwt-secret-here

# ==========================================
# POSTGRESQL DATABASE
# ==========================================
DB_DATABASE=jobapp
DB_USERNAME=jobapp_user
DB_PASSWORD=your-strong-postgres-password

# ==========================================
# MONGODB DATABASE
# ==========================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your-strong-mongo-password
MONGO_DATABASE=jobapp

# ==========================================
# REDIS CACHE
# ==========================================
REDIS_PASSWORD=your-strong-redis-password

# ==========================================
# REVERB WEBSOCKET
# ==========================================
REVERB_APP_ID=your-reverb-app-id
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8090
REVERB_SERVER_HOST=ws.jobswipe.site
REVERB_SERVER_PORT=443
REVERB_SCHEME=https

# ==========================================
# MAIL CONFIGURATION
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
MAIL_FROM_ADDRESS=noreply@jobswipe.site

# ==========================================
# FRONTEND
# ==========================================
NEXT_PUBLIC_API_URL=https://api.jobswipe.site

# ==========================================
# NOTES
# ==========================================
# 1. Generate APP_KEY: php artisan key:generate --show
# 2. Generate JWT_SECRET: openssl rand -base64 32
# 3. Generate Reverb credentials: php artisan reverb:install (copy from .env)
# 4. Use strong random passwords for all database credentials
# 5. Never commit this file to version control
# 6. Keep a secure backup of this file
