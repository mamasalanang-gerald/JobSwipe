# Render Environment Variables Template
# Copy these to your Render service environment variables
# DO NOT commit actual values to git

# Application
APP_NAME=JobApp
APP_ENV=production
APP_DEBUG=false
APP_KEY=                    # Generate with: php artisan key:generate --show
APP_URL=                    # Will be: https://your-service-name.onrender.com

# Database - PostgreSQL (from Render PostgreSQL service)
DB_CONNECTION=pgsql
DB_HOST=                    # From Render PostgreSQL internal connection
DB_PORT=5432
DB_DATABASE=                # From Render PostgreSQL service
DB_USERNAME=                # From Render PostgreSQL service
DB_PASSWORD=                # From Render PostgreSQL service

# MongoDB - External service (MongoDB Atlas recommended)
MONGO_HOST=                 # MongoDB Atlas connection string
MONGO_PORT=27017
MONGO_ROOT_USERNAME=        # MongoDB Atlas username
MONGO_ROOT_PASSWORD=        # MongoDB Atlas password
MONGO_DATABASE=jobapp

# Redis - From Render Redis service
REDIS_HOST=                 # From Render Redis internal connection
REDIS_PORT=6379
REDIS_PASSWORD=             # From Render Redis service

# Authentication
JWT_SECRET=                 # Generate with: php artisan jwt:secret --show
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Security
BCRYPT_ROUNDS=12

# Storage
FILESYSTEM_DISK=local

# Queue
QUEUE_CONNECTION=redis

# Mail (Configure with your email service)
MAIL_MAILER=smtp
MAIL_HOST=                  # e.g., smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=              # Your email service username
MAIL_PASSWORD=              # Your email service password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com

# Frontend URLs (Update when you deploy frontend)
FRONTEND_WEB_URL=https://your-frontend.onrender.com
FRONTEND_MOBILE_URL=

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Logging (Optimized for Render)
LOG_CHANNEL=stderr
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null
LOG_STACK=single