{
  "expo": {
    "name": "JobApp",
    "slug": "jobapp",
    "version": "1.0.0",
    "scheme": "jobapp",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "jsEngine": "hermes",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location"
        }
      ]
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.jobapp.mobile"
    },
    "android": {
      "package": "com.jobapp.mobile"
    },
    "githubUrl": "https://github.com/yourusername/jobapp"
  }
}