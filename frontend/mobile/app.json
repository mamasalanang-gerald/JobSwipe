{
  "expo": {
    "name": "JobApp",
    "slug": "jobapp",
    "version": "1.0.0",
    "scheme": "jobapp",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "jsEngine": "hermes",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location"
        }
      ]
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.jobapp.mobile"
    },
    "android": {
      "package": "com.jobapp.mobile",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "githubUrl": "https://github.com/yourusername/jobapp",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c27939a-3dd7-4757-8a8f-d91aec8992a4"
      }
    }
  }
}
